{
  "cli": {
    "version": ">= 18.4.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "node": "20.18.0",
      "env": {
        "NODE_OPTIONS": "--max-old-space-size=4096",
        "NPM_CONFIG_LEGACY_PEER_DEPS": "true"
      }
    },
    "demo": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "node": "20.18.0",
      "env": {
        "NODE_OPTIONS": "--max-old-space-size=4096",
        "NPM_CONFIG_LEGACY_PEER_DEPS": "true",
        "EXPO_PUBLIC_API_URL": "https://match4marriage-api-production-54ea.up.railway.app",
        "EXPO_PUBLIC_DEMO_MODE": "true"
      }
    },
    "production": {
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {}
  }
}
