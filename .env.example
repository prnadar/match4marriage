# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=Bandhan API
ENVIRONMENT=development
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://bandhan:bandhan_dev_secret@localhost:5432/bandhan
POSTGRES_PASSWORD=bandhan_dev_secret

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth0 ─────────────────────────────────────────────────────────────────────
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=xxx
AUTH0_CLIENT_SECRET=xxx
AUTH0_AUDIENCE=https://api.bandhan.in

# ── AWS / S3 ──────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=xxx
AWS_SECRET_ACCESS_KEY=xxx
AWS_S3_BUCKET=bandhan-media-dev
AWS_REGION=ap-south-1
AWS_CLOUDFRONT_DOMAIN=

# ── Razorpay ──────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=xxx
RAZORPAY_KEY_SECRET=xxx
RAZORPAY_WEBHOOK_SECRET=xxx

# ── Stripe (diaspora) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=xxx
STRIPE_WEBHOOK_SECRET=xxx

# ── Twilio ────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=xxx
TWILIO_AUTH_TOKEN=xxx
TWILIO_PHONE_NUMBER=+91xxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ── AI / ML ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=xxx
ANTHROPIC_API_KEY=xxx
PINECONE_API_KEY=xxx
PINECONE_INDEX=bandhan-profiles

# ── Email ─────────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=xxx
SENDGRID_FROM_EMAIL=hello@bandhan.in

# ── Multi-tenancy ─────────────────────────────────────────────────────────────
DEFAULT_TENANT_SLUG=bandhan
